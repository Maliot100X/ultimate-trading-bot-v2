{
  "version": 2,
  "builds": [
    {
      "src": "web/next.config.js",
      "use": "@vercel/nextjs",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/web/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.ultimate-trading-bot.vercel.app",
    "NEXT_PUBLIC_WS_URL": "wss://api.ultimate-trading-bot.vercel.app/ws",
    "NEXT_PUBLIC_GMGN_API_KEY": "@gmgn_api_key",
    "NEXT_PUBLIC_SOLANA_RPC": "@solana_rpc_url",
    "NEXT_PUBLIC_TELEGRAM_BOT_TOKEN": "@telegram_bot_token"
  }
}